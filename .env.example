# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# MONGO_URI: The MongoDB database Connection String (e.g., mongodb+srv://username:password@cluster.mongodb.net/dbname or mongodb://localhost:27107/dbname)
# Used for cloud or local MongoDB database persistence. If not specified, falls back safely to local JSON file.
MONGO_URI=""

# CLOUDINARY CONFIGURATION:
# Register at Cloudinary.com to get your cloud name, API key, and API secret.
# When configured, any uploaded photos/assets are hosted on Cloudinary instead of local system.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

